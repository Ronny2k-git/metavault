generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Swap {
  id        Int      @id @default(autoincrement())
  amount    String   
  type      String   
  txHash    String   @unique
  sender    String
  vaultId   Int
  createdAt DateTime @default(now())

  // Relationship
  vault     Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId])
}

// onDelete: If a vault is removed all the swaps related to it will also be removed

model Vault {
  id                 Int      @id @default(autoincrement())
  address            String   
  vaultName          String
  logo               String
  banner             String
  creatorName        String
  description        String
  salt               String
  minDeposit         String
  maxDeposit         String
  startDate          DateTime
  endDate            DateTime
  chainId            Int
  assetTokenAddress  String
  assetTokenDecimals Int
  assetTokenName     String?
  assetTokenSymbol   String?
  userAddress        String?

  // Optional fields
  discord            String?
  telegram           String?
  twitter            String?
  tag                String?

  // Relationship
  swaps              Swap[]
}


model User {
  id            Int     @id @default(autoincrement())
  about         String
  avatarUrl     String
  webSite       String?
  userAddress   String  @unique
}