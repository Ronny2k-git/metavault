generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Vault {
  id                 Int      @id @default(autoincrement())
  address            String
  name               String
  logo               String
  banner             String
  creatorName        String
  description        String
  startsDate         DateTime
  endsDate           DateTime
  chainId            Int
  assetTokenAddress  String
  assetTokenDecimals Int
  assetTokenName     String
  assetTokenSymbol   String
  minDeposit         String

  // Optional fields
  maxDeposit         String?
  discordUrl         String?
  telegramUrl        String?
  twitterUrl         String?
  tag                String?
}